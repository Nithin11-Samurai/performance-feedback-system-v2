# ==========================================
# Server Configuration
# ==========================================
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

# ==========================================
# PostgreSQL Database
# ==========================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=performance_feedback
DB_USER=postgres
DB_PASSWORD=your_db_password
# Alternatively, a single connection string (takes precedence if set)
DATABASE_URL=

# ==========================================
# JWT Authentication
# ==========================================
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=replace_with_another_long_random_secret
JWT_REFRESH_EXPIRES_IN=7d

# ==========================================
# Claude AI (for performance summary generation)
# ==========================================
ANTHROPIC_API_KEY=your_anthropic_api_key
CLAUDE_MODEL=claude-sonnet-5

# ==========================================
# Email (Nodemailer - used for HR/Admin notifications)
# ==========================================
# Preferred for a Microsoft 365 / Outlook tenant — see README for the
# Azure AD app registration steps. If these 4 are all set, Graph is used
# and the SMTP_* block below is ignored entirely.
MS_GRAPH_TENANT_ID=your_azure_ad_tenant_id
MS_GRAPH_CLIENT_ID=your_azure_ad_app_client_id
MS_GRAPH_CLIENT_SECRET=your_azure_ad_app_client_secret
MS_GRAPH_SENDER_EMAIL=noreply@pinksamurais.com

# Fallback if the Graph vars above aren't set — plain SMTP (Gmail,
# SendGrid, Mailgun, or M365's own SMTP AUTH if enabled for the mailbox).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_email_app_password
SMTP_FROM_NAME="Performance Feedback System"

# ==========================================
# File Uploads
# ==========================================
MAX_FILE_SIZE_MB=5
UPLOAD_DIR=uploads

# ==========================================
# Rate Limiting
# ==========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200
